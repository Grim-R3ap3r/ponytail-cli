#!/usr/bin/env bash
# ponytail — AI-powered PR review CLI (bugs · regression · over-engineering)
# Usage: ponytail <PR> [options]    or    ponytail review <PR> [options]
#        ponytail setup             check dependencies and configuration
set -euo pipefail

VERSION="3.0.1"

# ── colors (disabled when piped) ──────────────────────────────────────
# Soft 256-color accents when the terminal supports them; else basic ANSI.
if [[ -t 1 ]]; then
  RST=$'\033[0m'  B=$'\033[1m'  DIM=$'\033[2m'  ITA=$'\033[3m'
  RED=$'\033[31m'  GRN=$'\033[32m'  YLW=$'\033[33m'
  BLU=$'\033[34m'  MAG=$'\033[35m'  CYN=$'\033[36m'
  BRED=$'\033[1;31m'  BGRN=$'\033[1;32m'  BYLW=$'\033[1;33m'
  BCYN=$'\033[1;36m'  BMAG=$'\033[1;35m'  BBLU=$'\033[1;34m'
  if [[ "${COLORTERM:-}" == *truecolor* || "${TERM:-}" == *-256color* || "${TERM:-}" == xterm-kitty ]]; then
    ACC=$'\033[38;5;216m'   # peach border
    ACC2=$'\033[38;5;180m'  # warm label
    MUTE=$'\033[38;5;245m'  # muted text
    BUGC=$'\033[38;5;203m'
    REGC=$'\033[38;5;221m'
    PONC=$'\033[38;5;116m'
    OKC=$'\033[38;5;114m'
  else
    ACC=$CYN  ACC2=$YLW  MUTE=$DIM
    BUGC=$RED REGC=$YLW PONC=$CYN OKC=$GRN
  fi
else
  RST='' B='' DIM='' ITA='' RED='' GRN='' YLW=''
  BLU='' MAG='' CYN='' BRED='' BGRN='' BYLW=''
  BCYN='' BMAG='' BBLU=''
  ACC='' ACC2='' MUTE='' BUGC='' REGC='' PONC='' OKC=''
fi

# ── config ────────────────────────────────────────────────────────────
# Cursor SDK: "auto" lets the server pick. Override with CURSOR_MODEL / CURSOR_MODEL_REVIEW.
CURSOR_MODEL="${CURSOR_MODEL:-auto}"
CURSOR_MODEL_REVIEW="${CURSOR_MODEL_REVIEW:-auto}"
ANTHROPIC_MODEL="${ANTHROPIC_MODEL:-claude-sonnet-4-20250514}"
ANTHROPIC_MODEL_REVIEW="${ANTHROPIC_MODEL_REVIEW:-claude-opus-4-6}"
# ponytail: agent mode — bugs/regression run with local tools (grep/read) against PR head.
PONYTAIL_AGENT="${PONYTAIL_AGENT:-1}"
MAX_DIFF_BYTES=150000
MAX_FILE_BYTES=50000         # per-file cap when fetching full context
MAX_CONTEXT_FILES="${MAX_CONTEXT_FILES:-20}"       # fetch at most this many changed files
CONFIDENCE_THRESHOLD="${CONFIDENCE_THRESHOLD:-7}"  # 1-10; drop findings below this
PONYTAIL_MIN_ADDED="${PONYTAIL_MIN_ADDED:-80}"     # skip over-eng pass for tiny diffs
MAX_INLINE_COMMENTS="${MAX_INLINE_COMMENTS:-8}"    # hard cap on live posts
POST_DELAY=0.5
BOX_W=58   # inner content width (between the side borders)

# ── globals ───────────────────────────────────────────────────────────
PR=""
REPO=""
COMMIT=""
HEAD_BRANCH=""
BASE_BRANCH=""
PR_TITLE=""
PR_BODY=""
ADDED_LINES=0
DRY_RUN=false
PASSES=()
TMPDIR_PT=""
AI_ENGINE=""
AGENT_WORKSPACE=""   # local checkout of PR head for tool-using review
REVIEW_MODE="oneshot"

# ── cleanup ───────────────────────────────────────────────────────────
cleanup() { [[ -n "${TMPDIR_PT:-}" ]] && rm -rf "$TMPDIR_PT" || :; }
trap cleanup EXIT

# ── pretty helpers ────────────────────────────────────────────────────
# Build a horizontal rule of N ─ characters (portable, no seq dependency).
_rule() {
  local n="$1" out="" i
  for (( i=0; i<n; i++ )); do out+="─"; done
  printf '%s' "$out"
}

# Outer rule width: content has one pad space on each side → BOX_W + 2
_box_outer() { echo $(( BOX_W + 2 )); }

box_top() {
  local title="${1:-}" outer
  outer=$(_box_outer)
  if [[ -z "$title" ]]; then
    echo "  ${ACC}╭$(_rule "$outer")╮${RST}"
    return
  fi
  local tlen=${#title} left right inner
  inner=$(( outer - tlen - 2 ))
  (( inner < 2 )) && inner=2
  left=$(( inner / 2 ))
  right=$(( inner - left ))
  printf "  ${ACC}╭%s ${ACC2}%s${ACC} %s╮${RST}\n" \
    "$(_rule "$left")" "$title" "$(_rule "$right")"
}

box_bot() {
  echo "  ${ACC}╰$(_rule "$(_box_outer)")╯${RST}"
}

box_sep() {
  echo "  ${ACC}├$(_rule "$(_box_outer)")┤${RST}"
}

# Truncate a plain string to at most n characters (ellipsis if cut).
_trunc() {
  local s="$1" n="$2"
  if (( ${#s} > n )); then
    printf '%s' "${s:0:$((n-1))}…"
  else
    printf '%s' "$s"
  fi
}

# Plain padded row (no ANSI in the padded string — keeps borders aligned).
box_row() {
  local text
  text=$(_trunc "$1" "$BOX_W")
  printf "  ${ACC}│${RST} %-${BOX_W}s ${ACC}│${RST}\n" "$text"
}

# Row with left label (plain) + right value (colored separately).
# Usage: box_kv "Bugs / correctness" "1" "$BUGC"
box_kv() {
  local label="$1" value="$2" vcolor="${3:-$RST}"
  local lpad vpad
  value=$(_trunc "$value" 8)
  vpad=${#value}
  lpad=$(( BOX_W - vpad - 1 ))
  (( lpad < 1 )) && lpad=1
  label=$(_trunc "$label" "$lpad")
  printf "  ${ACC}│${RST} %-${lpad}s ${vcolor}%s${RST} ${ACC}│${RST}\n" "$label" "$value"
}

# Label row + cyan command row (both clipped to BOX_W).
box_cmd() {
  local label="$1" cmd="$2"
  box_row "• ${label}"
  local shown
  shown=$(_trunc "  ${cmd}" "$BOX_W")
  # shown is plain length BOX_W; color the command text only
  printf "  ${ACC}│${RST} ${BCYN}%-${BOX_W}s${RST} ${ACC}│${RST}\n" "$shown"
}

hr() { echo "  ${MUTE}$(_rule $((BOX_W + 2)))${RST}"; }

logo() {
  echo ""
  box_top "ponytail"
  box_row "lazy senior reviews · v${VERSION}"
  box_bot
  echo ""
}

banner() {
  echo ""
  box_top "$1"
  box_row "ponytail · v${VERSION}"
  box_bot
  echo ""
}

die() {
  echo "" >&2
  box_top "error" >&2
  printf "  ${ACC}│${RST} ${BRED}%-${BOX_W}s${RST} ${ACC}│${RST}\n" "$*" >&2
  box_sep >&2
  printf "  ${ACC}│${RST} ${MUTE}%-${BOX_W}s${RST} ${ACC}│${RST}\n" "try   ponytail --help" >&2
  printf "  ${ACC}│${RST} ${MUTE}%-${BOX_W}s${RST} ${ACC}│${RST}\n" "check ponytail setup" >&2
  box_bot >&2
  echo "" >&2
  exit 1
}

info() { echo "  ${MUTE}→${RST} $*"; }
ok()   { printf "  ${OKC}✓${RST}  ${B}%-14s${RST} %s\n" "$1" "$2"; }
fail() { printf "  ${BUGC}✗${RST}  ${B}%-14s${RST} %s\n" "$1" "$2"; }
warn() { printf "  ${REGC}!${RST}  ${B}%-14s${RST} %s\n" "$1" "$2"; }

tip() {
  printf "  ${MUTE}%-8s${RST} ${BCYN}%s${RST}\n" "$1" "$2" >&2
}

suggest() {
  printf "  ${MUTE}%-28s${RST} ${BCYN}%s${RST}\n" "$1" "$2"
}

pass_color() {
  case "$1" in
    bugs)       echo -n "$BUGC" ;;
    regression) echo -n "$REGC" ;;
    ponytail)   echo -n "$PONC" ;;
    *)          echo -n "$RST" ;;
  esac
}

pass_label() {
  case "$1" in
    bugs)       echo "bugs" ;;
    regression) echo "regression" ;;
    ponytail)   echo "over-eng" ;;
    *)          echo "$1" ;;
  esac
}

section() {
  echo "  ${ACC2}${B}$1${RST}"
  echo ""
}

# Parse "1050" or "https://github.com/OWNER/REPO/pull/1050" into PR + REPO.
# Sets PR; sets REPO only when the URL includes owner/repo.
parse_pr_ref() {
  local ref="$1"
  if [[ "$ref" =~ ^[0-9]+$ ]]; then
    PR="$ref"
    return
  fi
  # https://github.com/owner/repo/pull/123  (optional trailing slash / fragment)
  if [[ "$ref" =~ ^https?://github\.com/([^/]+)/([^/]+)/pull/([0-9]+)(/.*)?$ ]]; then
    local owner="${BASH_REMATCH[1]}"
    local name="${BASH_REMATCH[2]}"
    PR="${BASH_REMATCH[3]}"
    [[ -z "$REPO" ]] && REPO="${owner}/${name}"
    return
  fi
  # github.com/owner/repo/pull/123 (no scheme)
  if [[ "$ref" =~ ^github\.com/([^/]+)/([^/]+)/pull/([0-9]+)(/.*)?$ ]]; then
    local owner="${BASH_REMATCH[1]}"
    local name="${BASH_REMATCH[2]}"
    PR="${BASH_REMATCH[3]}"
    [[ -z "$REPO" ]] && REPO="${owner}/${name}"
    return
  fi
  die "expected a PR number or GitHub URL — e.g. ponytail 1050 or ponytail https://github.com/OWNER/REPO/pull/1050"
}

# ── home / usage ──────────────────────────────────────────────────────
usage() {
  logo
  box_top "commands"
  box_row "ponytail <PR|URL>              review a PR"
  box_row "ponytail review <PR|URL> …     with flags"
  box_row "ponytail setup                 check env"
  box_row "ponytail --help / --version    meta"
  box_sep
  box_row "Flags"
  box_row "  --repo OWNER/REPO"
  box_row "  --pass bugs|regression|ponytail|all"
  box_row "  --dry-run"
  box_sep
  box_row "Try next"
  box_row "  ponytail setup"
  box_row "  ponytail 162 --dry-run"
  box_row "  ponytail <PR-URL> --dry-run"
  box_sep
  box_row "API keys → ~/.zshrc"
  box_row "  export CURSOR_API_KEY=…"
  box_row "  export ANTHROPIC_API_KEY=…"
  box_bot
  echo ""
  echo "  ${MUTE}docs${RST}  ${ACC}https://github.com/Grim-R3ap3r/ponytail-cli${RST}"
  echo ""
}

# ── setup command ─────────────────────────────────────────────────────
cmd_setup() {
  banner "setup check"
  local all_ok=true
  local has_cursor=false
  local has_anthropic=false
  local gh_user="you"
  local detected_repo=""

  if command -v gh &>/dev/null; then
    local gh_ver
    gh_ver=$(gh --version | head -1 | awk '{print $3}')
    ok "gh" "installed ($gh_ver)"
  else
    fail "gh" "missing — brew install gh"
    all_ok=false
  fi

  if gh auth token &>/dev/null; then
    gh_user=$(gh api user -q .login 2>/dev/null || echo "you")
    ok "gh auth" "signed in as ${B}${gh_user}${RST}"
  else
    fail "gh auth" "run: gh auth login"
    all_ok=false
  fi

  if command -v jq &>/dev/null; then
    ok "jq" "installed"
  else
    fail "jq" "missing — brew install jq"
    all_ok=false
  fi

  if command -v curl &>/dev/null; then
    ok "curl" "installed"
  else
    fail "curl" "missing"
    all_ok=false
  fi

  if [[ -n "${CURSOR_API_KEY:-}" ]]; then
    has_cursor=true
    ok "CURSOR_API_KEY" "set ${DIM}(Cursor engine)${RST}"
    ok "review model" "${CURSOR_MODEL_REVIEW} ${DIM}(bugs/regression)${RST}"
    ok "other model" "${CURSOR_MODEL} ${DIM}(ponytail/verify)${RST}"
  else
    warn "CURSOR_API_KEY" "not set"
  fi
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    has_anthropic=true
    ok "ANTHROPIC_API_KEY" "set ${DIM}(Anthropic fallback)${RST}"
    if ! $has_cursor; then
      ok "review model" "${ANTHROPIC_MODEL_REVIEW} ${DIM}(bugs/regression)${RST}"
      ok "other model" "${ANTHROPIC_MODEL} ${DIM}(ponytail/verify)${RST}"
    fi
  else
    warn "ANTHROPIC_API_KEY" "not set"
  fi
  if ! $has_cursor && ! $has_anthropic; then
    fail "API key" "add CURSOR_API_KEY or ANTHROPIC_API_KEY to ~/.zshrc"
    all_ok=false
  fi

  if $has_cursor; then
    if command -v node &>/dev/null; then
      ok "node" "$(node --version)"
      if NODE_PATH=$(npm root -g) node -e "require('@cursor/sdk')" &>/dev/null; then
        ok "@cursor/sdk" "ready"
      else
        warn "@cursor/sdk" "run: npm install -g @cursor/sdk"
      fi
    else
      warn "node" "needed for Cursor engine"
    fi
  fi

  local skill_path
  if skill_path=$(resolve_ponytail_skill); then
    ok "ponytail-review" "$skill_path"
  else
    warn "ponytail-review" "skill missing — reinstall or set PONYTAIL_SKILL"
  fi

  detected_repo=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || true)

  echo ""
  hr
  if $all_ok; then
    echo "  ${BGRN}✓  You're ready to review.${RST}"
  else
    echo "  ${BRED}✗  Fix the failed checks above, then re-run setup.${RST}"
  fi
  echo ""
  section "Suggested commands"
  suggest "see all commands" "ponytail --help"
  if $all_ok; then
    if [[ -n "$detected_repo" ]]; then
      suggest "preview PR in this repo" "ponytail <PR> --dry-run"
      suggest "post review here"        "ponytail <PR>"
      echo ""
      echo "  ${DIM}detected repo:${RST} ${B}${detected_repo}${RST}"
    else
      suggest "preview any PR" "ponytail <PR> --repo OWNER/REPO --dry-run"
      suggest "post a review"  "ponytail <PR> --repo OWNER/REPO"
    fi
    suggest "bugs only" "ponytail <PR> --pass bugs --dry-run"
  else
    if ! command -v gh &>/dev/null; then
      suggest "install GitHub CLI" "brew install gh"
    fi
    if ! gh auth token &>/dev/null; then
      suggest "log in to GitHub" "gh auth login"
    fi
    if ! $has_cursor && ! $has_anthropic; then
      suggest "add Cursor key" "echo 'export CURSOR_API_KEY=...' >> ~/.zshrc"
      suggest "reload shell"   "source ~/.zshrc"
    fi
  fi
  echo ""
}

# ── arg parse ─────────────────────────────────────────────────────────
parse_review_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage; exit 0 ;;
      --repo)
        [[ $# -lt 2 ]] && die "--repo needs OWNER/REPO"
        REPO="$2"; shift 2 ;;
      --pass)
        [[ $# -lt 2 ]] && die "--pass needs bugs|regression|ponytail|all"
        case "$2" in
          all) PASSES=(bugs regression ponytail) ;;
          bugs|regression|ponytail) PASSES+=("$2") ;;
          *) die "unknown pass '$2' — use bugs, regression, ponytail, or all" ;;
        esac
        shift 2 ;;
      --dry-run) DRY_RUN=true; shift ;;
      -*)        die "unknown flag '$1' — try ponytail --help" ;;
      *)
        [[ -n "$PR" ]] && die "unexpected argument '$1'"
        parse_pr_ref "$1"
        shift
        ;;
    esac
  done
  [[ -z "$PR" ]] && die "missing PR — e.g. ponytail 162 --dry-run"
  [[ ${#PASSES[@]} -eq 0 ]] && PASSES=(bugs regression ponytail)
  if [[ -z "$REPO" ]]; then
    REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null) \
      || die "can't detect repo — pass --repo OWNER/REPO"
  fi
  if [[ -n "${CURSOR_API_KEY:-}" ]]; then
    AI_ENGINE="cursor"
  elif [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    AI_ENGINE="anthropic"
  else
    die "no API key — set CURSOR_API_KEY or ANTHROPIC_API_KEY in ~/.zshrc"
  fi
  TMPDIR_PT=$(mktemp -d)
}

# ── fetch PR ──────────────────────────────────────────────────────────
fetch_pr() {
  local pr_json
  pr_json=$(gh pr view "$PR" --repo "$REPO" \
    --json headRefOid,headRefName,baseRefName,title,body 2>/dev/null) \
    || die "can't read PR #${PR} in ${REPO}"

  COMMIT=$(echo "$pr_json" | jq -r '.headRefOid')
  HEAD_BRANCH=$(echo "$pr_json" | jq -r '.headRefName')
  BASE_BRANCH=$(echo "$pr_json" | jq -r '.baseRefName')
  PR_TITLE=$(echo "$pr_json" | jq -r '.title // ""')
  PR_BODY=$(echo "$pr_json" | jq -r '.body // ""')

  gh pr diff "$PR" --repo "$REPO" > "$TMPDIR_PT/diff"
  local sz
  sz=$(wc -c < "$TMPDIR_PT/diff" | tr -d ' ')
  [[ "$sz" -eq 0 ]] && die "PR #${PR} has an empty diff"
  if (( sz > MAX_DIFF_BYTES )); then
    info "diff ${sz}B exceeds ${MAX_DIFF_BYTES}B — truncating"
    head -c "$MAX_DIFF_BYTES" "$TMPDIR_PT/diff" > "$TMPDIR_PT/diff.t"
    mv "$TMPDIR_PT/diff.t" "$TMPDIR_PT/diff"
  fi

  ADDED_LINES=$(grep -c '^+[^+]' "$TMPDIR_PT/diff" 2>/dev/null || echo 0)

  fetch_file_context
  prepare_pr_workspace

  local human_sz
  if (( sz >= 1024 )); then
    human_sz="$(( sz / 1024 ))KB"
  else
    human_sz="${sz}B"
  fi
  local ctx_count
  ctx_count=$(wc -l < "$TMPDIR_PT/file_list" 2>/dev/null | tr -d ' ')
  [[ -z "$ctx_count" ]] && ctx_count=0

  local mode="${BGRN}live${RST}"
  $DRY_RUN && mode="${BYLW}dry-run${RST}"

  echo "  ${B}#${PR}${RST}  ${PR_TITLE}"
  echo "  ${DIM}${REPO}${RST}"
  echo ""
  echo "  ${CYN}${HEAD_BRANCH}${RST}  ${DIM}→${RST}  ${GRN}${BASE_BRANCH}${RST}"
  echo "  ${DIM}commit${RST} ${COMMIT:0:12}   ${DIM}diff${RST} ${human_sz}   ${DIM}+lines${RST} ${ADDED_LINES}   ${DIM}files${RST} ${ctx_count}"
  echo "  ${DIM}engine${RST} ${AI_ENGINE}   ${DIM}confidence${RST} ≥${CONFIDENCE_THRESHOLD}   ${DIM}mode${RST} ${mode}"
  if [[ "$AI_ENGINE" == "cursor" ]]; then
    echo "  ${DIM}model${RST} review=${CURSOR_MODEL_REVIEW}   other=${CURSOR_MODEL}   ${DIM}review${RST} ${REVIEW_MODE}"
  else
    echo "  ${DIM}model${RST} review=${ANTHROPIC_MODEL_REVIEW}   other=${ANTHROPIC_MODEL}   ${DIM}review${RST} oneshot"
  fi
  echo ""
  hr
  echo ""
}

# ── fetch full file context ──────────────────────────────────────────
fetch_file_context() {
  : > "$TMPDIR_PT/file_context"
  : > "$TMPDIR_PT/file_list"

  # Prefer substantive source files over lockfiles; rank by added-line count.
  local ranked="$TMPDIR_PT/files_ranked"
  : > "$ranked"
  local cur="" adds=0
  while IFS= read -r line; do
    if [[ "$line" =~ ^diff\ --git\ a/.+\ b/(.+)$ ]]; then
      if [[ -n "$cur" ]]; then
        printf '%08d\t%s\n' "$adds" "$cur" >> "$ranked"
      fi
      cur="${BASH_REMATCH[1]}"
      adds=0
      continue
    fi
    [[ "$line" =~ ^\+[^+] ]] && adds=$((adds + 1))
  done < "$TMPDIR_PT/diff"
  if [[ -n "$cur" ]]; then
    printf '%08d\t%s\n' "$adds" "$cur" >> "$ranked"
  fi

  local files=()
  while IFS=$'\t' read -r _adds fpath; do
    case "$fpath" in
      go.sum|*/go.sum|package-lock.json|yarn.lock|pnpm-lock.yaml|*.min.js|*.pb.go) continue ;;
    esac
    files+=("$fpath")
  done < <(sort -rn "$ranked")

  local fetched=0
  for fpath in "${files[@]}"; do
    (( fetched >= MAX_CONTEXT_FILES )) && break
    local content
    content=$(gh api "repos/$REPO/contents/${fpath}?ref=${HEAD_BRANCH}" \
      -q '.content' 2>/dev/null || true)
    [[ -z "$content" ]] && continue
    local decoded
    decoded=$(echo "$content" | base64 -d 2>/dev/null || true)
    [[ -z "$decoded" ]] && continue
    local fsz=${#decoded}
    if (( fsz > MAX_FILE_BYTES )); then
      decoded="${decoded:0:$MAX_FILE_BYTES}
... (truncated at ${MAX_FILE_BYTES}B)"
    fi
    printf '\n--- FILE: %s ---\n%s\n' "$fpath" "$decoded" >> "$TMPDIR_PT/file_context"
    echo "$fpath" >> "$TMPDIR_PT/file_list"
    fetched=$((fetched + 1))
  done
  if (( fetched > 0 )); then
    info "fetched ${fetched} file(s) for context"
  fi

  build_file_line_index
  build_hunk_map
}

# Shallow-checkout PR head so the Cursor agent can grep/read the real tree.
prepare_pr_workspace() {
  AGENT_WORKSPACE=""
  REVIEW_MODE="oneshot"
  [[ "${PONYTAIL_AGENT:-1}" != "1" ]] && return 0
  [[ "$AI_ENGINE" != "cursor" ]] && return 0

  local ws="$TMPDIR_PT/workspace"
  info "cloning PR head for agent tools…"
  if ! gh repo clone "$REPO" "$ws" -- --depth 1 --no-checkout \
      >"$TMPDIR_PT/clone.out" 2>"$TMPDIR_PT/clone.err"; then
    warn "agent workspace" "clone failed — oneshot fallback"
    return 0
  fi

  if ! (
    cd "$ws" || exit 1
    # Prefer exact commit; fall back to pull/N/head ref.
    if git fetch --depth 1 origin "$COMMIT" 2>/dev/null; then
      git checkout --force "$COMMIT" >/dev/null 2>&1
    elif git fetch --depth 1 origin "pull/${PR}/head:ponytail-pr" 2>/dev/null; then
      git checkout --force ponytail-pr >/dev/null 2>&1
    else
      exit 1
    fi
  ); then
    warn "agent workspace" "checkout failed — oneshot fallback"
    rm -rf "$ws"
    return 0
  fi

  AGENT_WORKSPACE="$ws"
  REVIEW_MODE="agent+tools"
  ok "agent workspace" "${COMMIT:0:12}"
}

# Index fetched files: path → line count (for evidence existence checks).
build_file_line_index() {
  : > "$TMPDIR_PT/file_line_counts"
  [[ ! -s "$TMPDIR_PT/file_context" ]] && return
  local cur="" n=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^---\ FILE:\ (.+)\ ---$ ]]; then
      if [[ -n "$cur" ]]; then
        printf '%s\t%d\n' "$cur" "$n" >> "$TMPDIR_PT/file_line_counts"
      fi
      cur="${BASH_REMATCH[1]}"
      n=0
      continue
    fi
    [[ -n "$cur" ]] && n=$((n + 1))
  done < "$TMPDIR_PT/file_context"
  if [[ -n "$cur" ]]; then
    printf '%s\t%d\n' "$cur" "$n" >> "$TMPDIR_PT/file_line_counts"
  fi
}

# Map of valid RIGHT-side diff lines (added + context) for GitHub inline comments.
# Writes: hunk_lines as "path:line" one per row; also paths list.
build_hunk_map() {
  : > "$TMPDIR_PT/hunk_lines"
  : > "$TMPDIR_PT/diff_paths"
  local path="" new_line=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^diff\ --git\ a/.+\ b/(.+)$ ]]; then
      path="${BASH_REMATCH[1]}"
      echo "$path" >> "$TMPDIR_PT/diff_paths"
      continue
    fi
    if [[ "$line" =~ ^@@\ -[0-9]+(,[0-9]+)?\ \+([0-9]+)(,[0-9]+)?\ @@ ]]; then
      new_line="${BASH_REMATCH[2]}"
      continue
    fi
    [[ -z "$path" ]] && continue
    case "$line" in
      ---*|+++*|index\ *|new\ file*|deleted\ file*|similarity\ *|rename\ *)
        continue
        ;;
      +*)
        # Added line on the RIGHT side — valid attach target.
        printf '%s:%s\n' "$path" "$new_line" >> "$TMPDIR_PT/hunk_lines"
        new_line=$((new_line + 1))
        ;;
      -*)
        # Deleted from LEFT only — do not advance new_line.
        ;;
      \\*)
        # "\ No newline at end of file"
        ;;
      *)
        # Context line — also valid as RIGHT side attach in many GitHub cases;
        # we record it but prefer snapping to nearest including added.
        printf '%s:%s\n' "$path" "$new_line" >> "$TMPDIR_PT/hunk_lines"
        new_line=$((new_line + 1))
        ;;
    esac
  done < "$TMPDIR_PT/diff"
  sort -u "$TMPDIR_PT/hunk_lines" -o "$TMPDIR_PT/hunk_lines"
  sort -u "$TMPDIR_PT/diff_paths" -o "$TMPDIR_PT/diff_paths"
}

# Snap a proposed line to a valid RIGHT-side diff line for path.
# Prints snapped line, or empty if none within window.
snap_line_to_hunk() {
  local path="$1" want="$2"
  local window="${3:-25}"
  [[ -z "$path" || -z "$want" ]] && return 1
  if grep -qxF "${path}:${want}" "$TMPDIR_PT/hunk_lines" 2>/dev/null; then
    echo "$want"
    return 0
  fi
  local best="" bestdist=999999 line dist
  while IFS= read -r entry; do
    [[ "$entry" == "$path":* ]] || continue
    line="${entry##*:}"
    [[ "$line" =~ ^[0-9]+$ ]] || continue
    dist=$(( line > want ? line - want : want - line ))
    if (( dist <= window && dist < bestdist )); then
      bestdist=$dist
      best=$line
    fi
  done < "$TMPDIR_PT/hunk_lines"
  if [[ -n "$best" ]]; then
    echo "$best"
    return 0
  fi
  return 1
}

# True if path exists in fetched files or in the diff.
path_known() {
  local path="$1"
  grep -qxF "$path" "$TMPDIR_PT/file_list" 2>/dev/null && return 0
  grep -qxF "$path" "$TMPDIR_PT/diff_paths" 2>/dev/null && return 0
  return 1
}

# True if path:line is plausible given what we fetched.
# Prefer exact fetched file line-count; else require the line appears in the hunk map.
evidence_pinpoint_exists() {
  local path="$1" line="$2"
  path_known "$path" || return 1
  [[ "$line" =~ ^[0-9]+$ ]] || return 1
  (( line < 1 )) && return 1

  local count=""
  count=$(awk -F'\t' -v p="$path" '$1==p {print $2; exit}' "$TMPDIR_PT/file_line_counts" 2>/dev/null || true)
  if [[ -n "$count" ]]; then
    (( line <= count )) && return 0
    return 1
  fi
  # File was in the diff but not fetched fully — only trust hunk map lines.
  grep -qxF "${path}:${line}" "$TMPDIR_PT/hunk_lines" 2>/dev/null
}

# Parse "path:line — note" / "path:line - note" → path, line on stdout as: path<TAB>line
parse_evidence_pinpoint() {
  local raw="$1"
  # Trim, then match path:digits at start.
  if [[ "$raw" =~ ^([A-Za-z0-9_./\\-]+):([0-9]+)([[:space:]].*)?$ ]]; then
    printf '%s\t%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
    return 0
  fi
  return 1
}

# Drop findings whose evidence pinpoints are hallucinated; also scrub bad evidence entries.
verify_evidence_exists() {
  local input_file="$1" output_file="$2"
  local kept="[]"
  local dropped=0
  local total=0

  while IFS= read -r row; do
    total=$((total + 1))
    local path evidence_json ok_evidence="[]"
    path=$(echo "$row" | jq -r '.path')
    evidence_json=$(echo "$row" | jq -c '.evidence // []')

    while IFS= read -r ev; do
      [[ -z "$ev" || "$ev" == "null" ]] && continue
      local parsed ep el
      parsed=$(parse_evidence_pinpoint "$ev") || continue
      ep="${parsed%%$'\t'*}"
      el="${parsed#*$'\t'}"
      if evidence_pinpoint_exists "$ep" "$el"; then
        ok_evidence=$(jq -c --arg e "$ev" '. + [$e]' <<<"$ok_evidence")
      fi
    done < <(echo "$evidence_json" | jq -r '.[]')

    local ok_n
    ok_n=$(echo "$ok_evidence" | jq 'length')
    if (( ok_n == 0 )); then
      dropped=$((dropped + 1))
      continue
    fi

    # Regression still needs ≥1 consumer outside finding path among surviving evidence.
    local body
    body=$(echo "$row" | jq -r '.body // ""')
    if [[ "$body" =~ [Rr]egression ]]; then
      local has_consumer
      has_consumer=$(echo "$ok_evidence" | jq --arg p "$path" \
        '[.[] | select(startswith($p + ":") | not)] | length')
      if (( has_consumer == 0 )); then
        dropped=$((dropped + 1))
        continue
      fi
    fi

    local updated
    updated=$(echo "$row" | jq -c --argjson ev "$ok_evidence" '.evidence = $ev')
    kept=$(jq -s -c '.[0] + [.[1]]' <(echo "$kept") <(echo "$updated"))
  done < <(jq -c '.[]' "$input_file")

  echo "$kept" > "$output_file"
  if (( dropped > 0 )); then
    info "evidence check: dropped ${dropped}/${total} (hallucinated or unverifiable pinpoints)"
  fi
}

# Snap each finding's line onto a valid diff hunk line; orphans → orphans.json.
snap_findings_to_hunks() {
  local input_file="$1"
  local attached="[]"
  local orphans="[]"
  local snapped_n=0 orphan_n=0

  while IFS= read -r row; do
    local path line snapped
    path=$(echo "$row" | jq -r '.path')
    line=$(echo "$row" | jq -r '.line')
    if snapped=$(snap_line_to_hunk "$path" "$line"); then
      if [[ "$snapped" != "$line" ]]; then
        snapped_n=$((snapped_n + 1))
        row=$(echo "$row" | jq -c --argjson l "$snapped" --argjson orig "$line" \
          '.line = $l | .snapped_from = $orig')
      fi
      attached=$(jq -s -c '.[0] + [.[1]]' <(echo "$attached") <(echo "$row"))
    else
      orphan_n=$((orphan_n + 1))
      row=$(echo "$row" | jq -c '.orphan = true')
      orphans=$(jq -s -c '.[0] + [.[1]]' <(echo "$orphans") <(echo "$row"))
    fi
  done < <(jq -c '.[]' "$input_file")

  echo "$attached" > "$TMPDIR_PT/deduped.json"
  echo "$orphans" > "$TMPDIR_PT/orphans.json"
  if (( snapped_n > 0 )); then
    info "snapped ${snapped_n} finding(s) onto nearest diff lines"
  fi
  if (( orphan_n > 0 )); then
    info "${orphan_n} finding(s) not on a diff line — will go in summary only"
  fi
}

